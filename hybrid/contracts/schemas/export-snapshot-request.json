{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/export-snapshot-request.json",
  "title": "ExportSnapshotRequest",
  "allOf": [
    {"$ref": "common-write-context.json"},
    {
      "type": "object",
      "required": ["format", "include_chapter_bodies"],
      "properties": {
        "format": {"type": "string", "enum": ["json", "markdown-bundle"]},
        "include_chapter_bodies": {"type": "boolean"},
        "revision": {"type": ["integer", "null"], "minimum": 0}
      }
    }
  ],
  "unevaluatedProperties": false
}
