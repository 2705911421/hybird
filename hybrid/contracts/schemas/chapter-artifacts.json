{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/chapter-artifacts.json",
  "title": "ChapterArtifacts",
  "type": "object",
  "additionalProperties": false,
  "required": ["chapter_number", "title", "body", "body_sha256", "summary", "events", "outline_fulfillment", "review", "state_mutation_proposal", "evidence_spans"],
  "properties": {
    "chapter_number": {"type": "integer", "minimum": 1},
    "title": {"type": "string", "minLength": 1, "maxLength": 300},
    "body": {"type": "string", "minLength": 1, "maxLength": 200000},
    "body_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 20000},
    "events": {"type": "array", "items": {"$ref": "event.json"}},
    "outline_fulfillment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planned_node_ids", "covered_node_ids", "missed_node_ids"],
      "properties": {
        "planned_node_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "covered_node_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "missed_node_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "review": {"$ref": "review-artifacts.json#/$defs/chapterReviewArtifact"},
    "state_mutation_proposal": {"$ref": "review-artifacts.json#/$defs/stateMutationProposal"},
    "evidence_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "start", "end"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "start": {"type": "integer", "minimum": 0},
          "end": {"type": "integer", "minimum": 1}
        }
      }
    },
    "agent_trace_id": {"type": "string", "maxLength": 200}
  }
}
