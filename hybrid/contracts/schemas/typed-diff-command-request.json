{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/typed-diff-command-request.json",
  "title": "TypedDiffCommandRequest",
  "allOf": [
    {"$ref": "common-write-context.json"},
    {
      "type": "object",
      "required": ["actor", "reason", "events"],
      "properties": {
        "actor": {"type": "string", "minLength": 1, "maxLength": 200},
        "reason": {"type": "string", "minLength": 1, "maxLength": 500},
        "events": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "event.json"}}
      }
    }
  ],
  "unevaluatedProperties": false
}
