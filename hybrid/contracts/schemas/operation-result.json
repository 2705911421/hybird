{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/operation-result.json",
  "title": "OperationResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "project_id", "status", "revision", "replayed", "result"],
  "properties": {
    "request_id": {"type": "string", "format": "uuid"},
    "project_id": {"type": "string"},
    "status": {"type": "string", "enum": ["accepted", "completed", "rejected", "pending", "degraded"]},
    "revision": {"type": "integer", "minimum": 0},
    "replayed": {"type": "boolean", "description": "True when returned from the idempotency ledger."},
    "result": {"type": "object"}
  }
}
