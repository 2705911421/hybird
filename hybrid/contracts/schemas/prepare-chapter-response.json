{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/prepare-chapter-response.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["commit_id", "prepare_id", "project_id", "chapter_number", "state", "current_revision", "expected_revision", "required_artifact_schema", "replayed"],
  "properties": {
    "commit_id": {"type": "string", "format": "uuid"},
    "prepare_id": {"type": "string", "format": "uuid"},
    "project_id": {"type": "string"},
    "chapter_number": {"type": "integer", "minimum": 1},
    "state": {"type": "string", "enum": ["PREPARED", "VALIDATED", "PERSISTING", "COMMITTED", "PROJECTING", "FINALIZED", "REJECTED", "ABORTED", "RECOVERY_REQUIRED"]},
    "current_revision": {"type": "integer", "minimum": 0},
    "expected_revision": {"type": "integer", "minimum": 0},
    "required_artifact_schema": {"type": "string"},
    "replayed": {"type": "boolean"}
  }
}
