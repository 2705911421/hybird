{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/chapter-aggregate-response.json",
  "type": "object", "additionalProperties": false,
  "required": ["project_id", "revision", "chapter_count", "latest_chapter", "total_characters", "chapters", "volumes"],
  "properties": {
    "project_id": {"type": "string"}, "revision": {"type": "integer", "minimum": 0}, "chapter_count": {"type": "integer", "minimum": 0},
    "latest_chapter": {"type": "integer", "minimum": 0}, "total_characters": {"type": "integer", "minimum": 0},
    "chapters": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["chapter_number", "character_count", "volume_id", "created_at", "updated_at", "finalized_at"], "properties": {"chapter_number": {"type": "integer", "minimum": 1}, "character_count": {"type": "integer", "minimum": 0}, "volume_id": {"type": ["string", "null"]}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}, "finalized_at": {"type": "string", "format": "date-time"}}}},
    "volumes": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["volume_id", "chapter_count", "character_count"], "properties": {"volume_id": {"type": "string"}, "chapter_count": {"type": "integer", "minimum": 0}, "character_count": {"type": "integer", "minimum": 0}}}}
  }
}
