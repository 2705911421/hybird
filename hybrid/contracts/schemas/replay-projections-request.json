{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/replay-projections-request.json",
  "title": "ReplayProjectionsRequest",
  "allOf": [
    {"$ref": "common-write-context.json"},
    {
      "type": "object",
      "required": ["projection_names", "from_event_sequence", "verify_only"],
      "properties": {
        "projection_names": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
        "from_event_sequence": {"type": "integer", "minimum": 0},
        "to_event_sequence": {"type": ["integer", "null"], "minimum": 0},
        "verify_only": {"type": "boolean"}
      }
    }
  ],
  "unevaluatedProperties": false
}
