{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "commit-recovery-request.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "project_id", "commit_id", "idempotency_key", "action", "reason", "admin_scope"],
  "properties": {
    "request_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "commit_id": { "type": "string", "format": "uuid" },
    "idempotency_key": { "type": "string", "minLength": 16, "maxLength": 200 },
    "action": { "enum": ["recover", "abort"] },
    "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
    "admin_scope": { "const": "story-runtime.commits.recover" }
  }
}
