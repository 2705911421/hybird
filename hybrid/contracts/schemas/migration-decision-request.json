{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/migration-decision-request.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["decisions"],
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["conflict_id", "decision"],
        "properties": {
          "conflict_id": { "type": "string", "minLength": 1 },
          "decision": { "enum": ["choose_candidate", "merge", "ignore", "quarantine"] },
          "candidate_id": { "type": ["string", "null"] },
          "note": { "type": ["string", "null"], "maxLength": 2000 }
        }
      }
    }
  }
}
