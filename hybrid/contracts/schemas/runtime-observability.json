{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/runtime-observability.json",
  "title": "Story Runtime Observability v1",
  "$defs": {
    "page": {
      "type": "object", "additionalProperties": false,
      "required": ["limit", "has_more", "next_cursor"],
      "properties": { "limit": {"type": "integer", "minimum": 1, "maximum": 100}, "has_more": {"type": "boolean"}, "next_cursor": {"type": ["string", "null"]} }
    },
    "overview": {
      "type": "object", "additionalProperties": false,
      "required": ["project_id", "runtime_state", "impact", "current_revision", "latest_chapter", "project_phase", "authority_mode", "active_prepares", "blocked_commits", "pending_recovery", "projection_health", "index_health", "last_successful_commit", "last_backup", "schema_version", "runtime_version"],
      "properties": {
        "project_id": {"type": "string"},
        "runtime_state": {"enum": ["healthy", "degraded", "unavailable", "version_mismatch", "migration_required", "database_locked", "recovery_required"]},
        "impact": {"type": "object", "additionalProperties": false, "required": ["what_happened", "reads_affected", "writes_affected", "retryable", "user_action", "disabled_actions"], "properties": {"what_happened": {"type": "string"}, "reads_affected": {"type": "boolean"}, "writes_affected": {"type": "boolean"}, "retryable": {"type": "boolean"}, "user_action": {"type": "string"}, "disabled_actions": {"type": "array", "items": {"type": "string"}}}},
        "current_revision": {"type": "integer", "minimum": 0}, "latest_chapter": {"type": "integer", "minimum": 0}, "project_phase": {"type": "string"}, "authority_mode": {"enum": ["legacy", "runtime"]},
        "active_prepares": {"type": "integer", "minimum": 0}, "blocked_commits": {"type": "integer", "minimum": 0}, "pending_recovery": {"type": "integer", "minimum": 0}, "projection_health": {"enum": ["ready", "degraded"]},
        "index_health": {"type": "object", "additionalProperties": false, "required": ["status", "lexical_documents", "vector_status", "last_indexed_chapter", "pending_items"], "properties": {"status": {"enum": ["ready", "degraded", "unavailable", "rebuilding"]}, "lexical_documents": {"type": "integer", "minimum": 0}, "vector_status": {"enum": ["ready", "not_configured", "degraded", "rebuilding"]}, "last_indexed_chapter": {"type": ["integer", "null"], "minimum": 0}, "pending_items": {"type": "integer", "minimum": 0}}},
        "last_successful_commit": {"type": ["string", "null"], "format": "date-time"}, "last_backup": {"type": ["string", "null"], "format": "date-time"}, "schema_version": {"type": "string"}, "runtime_version": {"type": "string"}
      }
    },
    "commitSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["commit_id", "chapter_number", "state", "request_id", "idempotency_status", "retryable", "resulting_revision", "created_at", "updated_at"],
      "properties": {"commit_id": {"type": "string"}, "chapter_number": {"type": "integer", "minimum": 1}, "state": {"type": "string"}, "request_id": {"type": "string"}, "idempotency_status": {"enum": ["recorded", "replayed", "unknown"]}, "retryable": {"type": "boolean"}, "resulting_revision": {"type": ["integer", "null"], "minimum": 0}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}}
    },
    "commitList": {"type": "object", "additionalProperties": false, "required": ["items", "page"], "properties": {"items": {"type": "array", "items": {"$ref": "#/$defs/commitSummary"}}, "page": {"$ref": "#/$defs/page"}}},
    "commitDetail": {
      "type": "object", "additionalProperties": false,
      "required": ["summary", "transitions", "artifact_checksum", "event_count", "projection_results", "validation_findings", "human_decision", "error", "repair_action"],
      "properties": {"summary": {"$ref": "#/$defs/commitSummary"}, "transitions": {"type": "array", "items": {"type": "object"}}, "artifact_checksum": {"type": ["string", "null"]}, "event_count": {"type": "integer", "minimum": 0}, "projection_results": {"type": "array", "items": {"type": "object"}}, "validation_findings": {"type": "array", "items": {"type": "object"}}, "human_decision": {"type": ["object", "null"]}, "error": {"type": ["object", "null"]}, "repair_action": {"type": ["string", "null"]}}
    },
    "eventList": {
      "type": "object", "additionalProperties": false, "required": ["items", "page"],
      "properties": {"items": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["sequence", "event_id", "event_type", "aggregate_type", "aggregate_id", "chapter_number", "revision", "summary", "evidence", "payload_preview", "payload_bytes", "payload_truncated", "created_at"], "properties": {"sequence": {"type": "integer", "minimum": 1}, "event_id": {"type": "string"}, "event_type": {"type": "string"}, "aggregate_type": {"type": ["string", "null"]}, "aggregate_id": {"type": ["string", "null"]}, "chapter_number": {"type": ["integer", "null"], "minimum": 1}, "revision": {"type": ["integer", "null"], "minimum": 0}, "summary": {"type": "string"}, "evidence": {"type": ["array", "null"], "items": {"type": "object"}}, "payload_preview": {"type": ["object", "null"]}, "payload_bytes": {"type": "integer", "minimum": 0}, "payload_truncated": {"type": "boolean"}, "created_at": {"type": ["string", "null"], "format": "date-time"}}}}, "page": {"$ref": "#/$defs/page"}}
    },
    "projection": {"type": "object", "additionalProperties": false, "required": ["projection", "checkpoint", "revision", "hash", "status", "retry_count", "last_error", "replay_capability", "updated_at"], "properties": {"projection": {"type": "string"}, "checkpoint": {"type": "integer", "minimum": 0}, "revision": {"type": "integer", "minimum": 0}, "hash": {"type": ["string", "null"]}, "status": {"type": "string"}, "retry_count": {"type": "integer", "minimum": 0}, "last_error": {"type": ["string", "null"]}, "replay_capability": {"enum": ["direct", "confirmation_required", "blocked"]}, "updated_at": {"type": "string", "format": "date-time"}}},
    "projectionList": {"type": "object", "additionalProperties": false, "required": ["items"], "properties": {"items": {"type": "array", "items": {"$ref": "#/$defs/projection"}}}},
    "doctor": {"type": "object", "additionalProperties": false, "required": ["project_id", "revision", "status", "checks"], "properties": {"project_id": {"type": "string"}, "revision": {"type": "integer", "minimum": 0}, "status": {"enum": ["ok", "warning", "blocked"]}, "checks": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["code", "status", "message", "repair", "retryable", "requires_confirmation"], "properties": {"code": {"type": "string"}, "status": {"enum": ["pass", "warning", "fail", "blocked"]}, "message": {"type": "string"}, "repair": {"type": ["string", "null"]}, "retryable": {"type": "boolean"}, "requires_confirmation": {"type": "boolean"}}}}}},
    "migration": {"type": "object", "additionalProperties": false, "required": ["status", "current_version", "target_version", "pending_versions", "resume_capability"], "properties": {"status": {"enum": ["current", "required", "in_progress", "interrupted", "blocked"]}, "current_version": {"type": "integer", "minimum": 0}, "target_version": {"type": "integer", "minimum": 0}, "pending_versions": {"type": "array", "items": {"type": "integer", "minimum": 0}}, "resume_capability": {"enum": ["not_needed", "confirmation_required", "blocked"]}}},
    "configuration": {"type": "object", "additionalProperties": false, "required": ["writes_enabled", "unified_review_enabled", "token_configured", "projection_output_configured", "observability_enabled", "recovery_enabled", "busy_timeout_ms", "secret_values_exposed"], "properties": {"writes_enabled": {"type": "boolean"}, "unified_review_enabled": {"type": "boolean"}, "token_configured": {"type": "boolean"}, "projection_output_configured": {"type": "boolean"}, "observability_enabled": {"type": "boolean"}, "recovery_enabled": {"type": "boolean"}, "busy_timeout_ms": {"type": "integer", "minimum": 1}, "secret_values_exposed": {"const": false}}},
    "reviewOverview": {"type": "object", "additionalProperties": false, "required": ["project_id", "total_artifacts", "open_findings", "blocking_findings", "latest_decision", "latest_decision_at"], "properties": {"project_id": {"type": "string"}, "total_artifacts": {"type": "integer", "minimum": 0}, "open_findings": {"type": "integer", "minimum": 0}, "blocking_findings": {"type": "integer", "minimum": 0}, "latest_decision": {"type": ["string", "null"]}, "latest_decision_at": {"type": ["string", "null"], "format": "date-time"}}},
    "recoveryJob": {"type": "object", "additionalProperties": false, "required": ["job_id", "project_id", "operation", "state", "requires_confirmation", "confirmation_token", "preview", "result", "progress", "cancellable", "error", "created_at", "updated_at", "completed_at", "audit_trail"], "properties": {"job_id": {"type": "string"}, "project_id": {"type": "string"}, "operation": {"enum": ["retry_outbox_item", "rebuild_lexical_index", "rebuild_vector_index", "replay_core_projection", "abort_prepared_commit", "restore_snapshot", "clear_retry_queue", "resume_interrupted_migration"]}, "state": {"enum": ["previewed", "running", "completed", "failed", "cancelled", "blocked"]}, "requires_confirmation": {"type": "boolean"}, "confirmation_token": {"type": ["string", "null"]}, "preview": {"type": "object"}, "result": {"type": ["object", "null"]}, "progress": {"type": "integer", "minimum": 0, "maximum": 100}, "cancellable": {"type": "boolean"}, "error": {"type": ["object", "null"]}, "created_at": {"type": "string", "format": "date-time"}, "updated_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": ["string", "null"], "format": "date-time"}, "audit_trail": {"type": "array", "items": {"type": "object"}}}},
    "recoveryJobList": {"type": "object", "additionalProperties": false, "required": ["items", "page"], "properties": {"items": {"type": "array", "items": {"$ref": "#/$defs/recoveryJob"}}, "page": {"$ref": "#/$defs/page"}}},
    "diagnosticReport": {"type": "object", "additionalProperties": false, "required": ["generated_at", "project_id", "versions", "non_sensitive_config", "commit_status", "projection_status", "doctor", "recent_errors", "checksums"], "properties": {"generated_at": {"type": "string", "format": "date-time"}, "project_id": {"type": "string"}, "versions": {"type": "object"}, "non_sensitive_config": {"type": "object"}, "commit_status": {"type": "object"}, "projection_status": {"type": "array", "items": {"$ref": "#/$defs/projection"}}, "doctor": {"$ref": "#/$defs/doctor"}, "recent_errors": {"type": "array", "items": {"type": "object"}}, "checksums": {"type": "array", "items": {"type": "object"}}}}
  }
}
