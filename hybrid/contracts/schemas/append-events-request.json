{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid.local/schemas/append-events-request.json",
  "title": "AppendEventsRequest",
  "allOf": [
    {"$ref": "common-write-context.json"},
    {
      "type": "object",
      "required": ["events", "reason"],
      "properties": {
        "events": {"type": "array", "minItems": 1, "maxItems": 1000, "items": {"$ref": "event.json"}},
        "reason": {"type": "string", "minLength": 1, "maxLength": 500},
        "admin_scope": {"type": "string", "const": "story-runtime.events.append"}
      }
    }
  ],
  "unevaluatedProperties": false
}
